---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Meta from '../components/Meta.astro';
const APP_STORE_URL = "https://apps.apple.com/nl/app/pocketgraph/id1604368926";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <Meta canonical="/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <script is:inline src="https://rybbit.resoftware.work/api/script.js" data-site-id="d2f58ef3c722" defer></script>
</head>
<body>

<canvas id="bg-canvas"></canvas>
<div class="bg-orb orb-1"></div>
<div class="bg-orb orb-2"></div>
<div class="bg-orb orb-3"></div>

<Nav />

<!-- ─── HERO ──────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1>
        Your graph database,<br />
        <em>in your pocket.</em>
      </h1>

      <p class="hero-sub">
        PocketGraph connects to any Neo4j or Memgraph database via the lightning-fast Bolt protocol — SSL-encrypted, query-ready, and beautifully visual. Available on iOS and iPadOS.
      </p>

      <div class="hero-cta">
        <a href={APP_STORE_URL} class="btn-store" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.15-2.19 1.28-2.17 3.82.02 3.02 2.65 4.03 2.68 4.04l-.06.26zM13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download on the App Store
        </a>
        <span class="btn-store btn-disabled" aria-disabled="true">
          <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
            <path d="M17,14.5l4.2-4.5L4.9,1.2C4.8,1.1,4.6,1.1,4.3,1L17,14.5z"/>
            <path d="M23,21l5.9-3.2c0.7-0.4,1.1-1,1.1-1.8s-0.4-1.5-1.1-1.8L23,11l-4.7,5L23,21z"/>
            <path d="M2.4,1.9C2.1,2.2,2,2.6,2,3V29c0,0.4,0.1,0.8,0.4,1.2L15.6,16L2.4,1.9z"/>
            <path d="M17,17.5L4.3,31c0.2,0,0.4-0.1,0.6-0.2L21.2,22L17,17.5z"/>
          </svg>
          Play Store &middot; Coming Soon
        </span>
        <span class="price-label">&euro;8.99 &middot; one-time</span>
      </div>

      <div class="platform-pills">
        <span>iOS 14.2+</span>
        <span>iPadOS 14.2+</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="screenshots">
        <img src="/screenshot1.jpg" alt="Graph visualization in PocketGraph" class="screenshot s1" />
        <img src="/screenshot2.jpg" alt="Cypher editor in PocketGraph" class="screenshot s2" />
      </div>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ─── FEATURES ──────────────────────────────────────────── -->
<section class="features">
  <div class="section-inner">
    <div class="section-label">
      <span class="mono">// capabilities</span>
    </div>
    <h2 class="section-title">Everything you need<br/>to explore your graph.</h2>

    <div class="feat-grid">
      <div class="feat-card">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>Bolt Protocol</h3>
        <p>Direct connection via the high-performance Bolt protocol. Fast queries, real-time results, zero latency overhead.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3>SSL Encrypted</h3>
        <p>All connections are encrypted via SSL/TLS. Your credentials and data stay private, even on untrusted networks.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="7" y1="7.5" x2="11" y2="16.5"/><line x1="17" y1="7.5" x2="13" y2="16.5"/></svg>
        </div>
        <h3>Graph Visualization</h3>
        <p>Nodes and relationships rendered as an interactive graph. Related nodes are included by default — understand your data at a glance.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <h3>Syntax Highlighting</h3>
        <p>A first-class Cypher editor with full syntax highlighting. Write queries with confidence and clear visual structure.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </div>
        <h3>Advanced Query Editor</h3>
        <p>A full-featured editor built for Cypher. Navigate history, edit with precision, and get clear error messages when something goes wrong.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
        </div>
        <h3>Multi-Database</h3>
        <p>Switch between databases with a simple picker. Manage multiple Neo4j and Memgraph instances and switch contexts without friction.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── COMPATIBLE WITH ───────────────────────────────────── -->
<section class="compat">
  <div class="section-inner compat-inner">
    <span class="compat-label">Works with</span>
    <div class="compat-logos">
      <a href="https://neo4j.com" target="_blank" rel="noopener"><img src="/neo4j-logo.png" alt="Neo4j" class="compat-logo" /></a>
      <a href="https://memgraph.com" target="_blank" rel="noopener"><img src="/memgraph-logo.webp" alt="Memgraph" class="compat-logo" /></a>
    </div>
  </div>
</section>

<!-- ─── CYPHER DEMO ────────────────────────────────────────── -->
<section class="demo">
  <div class="section-inner demo-inner">
    <div class="demo-text">
      <div class="section-label">
        <span class="mono">// query editor</span>
      </div>
      <h2>Write Cypher.<br /><span class="accent">See your graph.</span></h2>
      <p>
        PocketGraph's editor understands Cypher. Syntax is highlighted as you type, errors surface clearly, and results render as both a live graph and a structured table.
      </p>
      <a href={APP_STORE_URL} class="btn-ghost" target="_blank" rel="noopener">
        Try it for yourself &rarr;
      </a>
    </div>
    <div class="video-phone" id="video-thumb" title="Click to expand">
      <video autoplay muted loop playsinline id="video-preview">
        <source src="/demo.mp4" type="video/mp4" />
      </video>
      <div class="video-play-hint">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </div>
    </div>
  </div>
</section>

<!-- ─── VIDEO MODAL ───────────────────────────────────────── -->
<div id="video-modal" class="video-modal" aria-hidden="true">
  <div class="video-modal-backdrop"></div>
  <div class="video-modal-inner">
    <button class="video-modal-close" aria-label="Close">&times;</button>
    <div class="video-modal-phone">
      <video muted playsinline controls id="video-modal-player">
        <source src="/demo.mp4" type="video/mp4" />
      </video>
    </div>
  </div>
</div>

<!-- ─── CTA ───────────────────────────────────────────────── -->
<section class="cta">
  <div class="cta-glow"></div>
  <div class="section-inner cta-inner">
    <img src="/logo.png" alt="PocketGraph" class="cta-icon" />
    <div class="cta-text">
      <h2>Ready to explore your graph?</h2>
      <p>One-time purchase. No subscription. No limits.</p>
    </div>
    <div class="cta-buttons">
      <a href={APP_STORE_URL} class="btn-store large" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.15-2.19 1.28-2.17 3.82.02 3.02 2.65 4.03 2.68 4.04l-.06.26zM13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download on App Store &middot; &euro;8.99
      </a>
      <span class="btn-store large btn-disabled" aria-disabled="true">
        <svg width="22" height="22" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M17,14.5l4.2-4.5L4.9,1.2C4.8,1.1,4.6,1.1,4.3,1L17,14.5z"/>
          <path d="M23,21l5.9-3.2c0.7-0.4,1.1-1,1.1-1.8s-0.4-1.5-1.1-1.8L23,11l-4.7,5L23,21z"/>
          <path d="M2.4,1.9C2.1,2.2,2,2.6,2,3V29c0,0.4,0.1,0.8,0.4,1.2L15.6,16L2.4,1.9z"/>
          <path d="M17,17.5L4.3,31c0.2,0,0.4-0.1,0.6-0.2L21.2,22L17,17.5z"/>
        </svg>
        Google Play &middot; Coming Soon
      </span>
    </div>
  </div>
</section>

<Footer />

<style>
  :root {
    --bg:        #0c0c0c;
    --bg2:       #111111;
    --bg3:       #181818;
    --teal:      #e2e2e2;
    --teal-dim:  rgba(226, 226, 226, 0.1);
    --teal-glow: rgba(226, 226, 226, 0.18);
    --text:      #e8e8e8;
    --muted:     #9a9a9a;
    --border:    rgba(226, 226, 226, 0.1);
    --card-bg:   rgba(24, 24, 24, 0.8);
    --font-sans: 'Syne', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }
  .bg-orb {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }
  .orb-1 {
    width: 750px; height: 750px;
    top: -220px; right: -180px;
    background: radial-gradient(circle, rgba(210,210,230,0.06) 0%, transparent 65%);
    filter: blur(50px);
    animation: orbDrift1 24s ease-in-out infinite;
  }
  .orb-2 {
    width: 620px; height: 620px;
    bottom: 8%; left: -160px;
    background: radial-gradient(circle, rgba(190,190,215,0.05) 0%, transparent 65%);
    filter: blur(50px);
    animation: orbDrift2 30s ease-in-out infinite;
  }
  .orb-3 {
    width: 520px; height: 520px;
    top: 38%; left: 33%;
    background: radial-gradient(circle, rgba(220,220,235,0.035) 0%, transparent 65%);
    filter: blur(70px);
    animation: orbDrift3 38s ease-in-out infinite;
  }
  @keyframes orbDrift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    30%       { transform: translate(55px, 45px) scale(1.06); }
    65%       { transform: translate(-35px, 75px) scale(0.96); }
  }
  @keyframes orbDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%       { transform: translate(65px, -55px) scale(1.09); }
    72%       { transform: translate(25px, 35px) scale(0.94); }
  }
  @keyframes orbDrift3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%       { transform: translate(-45px, 65px) scale(1.1); }
    58%       { transform: translate(55px, -45px) scale(0.92); }
    80%       { transform: translate(-25px, -35px) scale(1.05); }
  }

  .section-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .mono  { font-family: var(--font-mono); }
  .teal  { color: var(--teal); }
  .accent { color: var(--teal); }

  /* ── HERO ── */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 2rem 80px;
  }
  .hero-inner {
    max-width: 1120px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 4rem;
    align-items: center;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--teal);
    border: 1px solid var(--border);
    background: var(--teal-dim);
    padding: 0.35rem 0.85rem;
    border-radius: 2px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s both;
  }
  .chip-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 8px var(--teal);
    animation: blink 2s infinite;
  }
  h1 {
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s 0.1s both;
  }
  h1 em {
    font-style: normal;
    color: var(--teal);
    text-shadow: 0 0 40px rgba(255, 255, 255, 0.25);
  }
  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #aaaaaa;
    max-width: 520px;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.6s 0.2s both;
  }
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    animation: fadeUp 0.6s 0.3s both;
    flex-wrap: wrap;
  }
  .price-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #aaaaaa;
  }
  .platform-pills {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.4s both;
  }
  .platform-pills span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #aaaaaa;
    border: 1px solid rgba(200, 200, 200, 0.2);
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    letter-spacing: 0.03em;
  }

  /* Screenshots */
  .hero-visual {
    position: relative;
    animation: fadeUp 0.8s 0.3s both;
  }
  .screenshots {
    position: relative;
    width: 100%;
    max-width: 520px;
    height: 620px;
    margin: 0 auto;
  }
  .screenshot {
    position: absolute;
    width: 260px;
    border-radius: 24px;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.08),
      0 24px 60px rgba(0,0,0,0.7);
    object-fit: cover;
  }
  .s1 {
    left: 0;
    top: 40px;
    transform: rotate(-2.5deg);
    z-index: 1;
  }
  .s2 {
    right: 0;
    top: 0;
    transform: rotate(1.5deg);
    z-index: 2;
  }

  /* Buttons */
  .btn-store {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--teal);
    color: #0c0c0c;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.85rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    letter-spacing: -0.01em;
  }
  .btn-store:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(255, 255, 255, 0.2);
    background: #ffffff;
  }
  .btn-disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
    background: transparent;
    color: var(--teal);
    border: 1px solid rgba(226,226,226,0.3);
  }
  .btn-store.large {
    font-size: 1.05rem;
    padding: 1rem 2rem;
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    color: var(--teal);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border-bottom: 1px solid var(--teal-dim);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--teal); }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeUp 1s 1s both;
  }
  @media (max-width: 768px) {
    .scroll-hint { display: none; }
  }
  .scroll-hint span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .scroll-line {
    width: 1px; height: 40px;
    background: linear-gradient(to bottom, var(--teal), transparent);
    animation: scrollDrop 2s 1.5s infinite;
  }

  /* ── FEATURES ── */
  .features {
    position: relative;
    z-index: 1;
    padding: 8rem 0;
  }
  .section-label {
    margin-bottom: 1rem;
  }
  .section-label .mono {
    font-size: 0.78rem;
    color: var(--teal);
    letter-spacing: 0.06em;
    opacity: 0.8;
  }
  .section-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 4rem;
  }
  .section-title.center { text-align: center; }
  .section-sub {
    color: #aaaaaa;
    font-size: 1rem;
    margin-top: -3rem;
    margin-bottom: 3.5rem;
  }
  .section-sub.center { text-align: center; }
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .feat-card {
    background: var(--card-bg);
    padding: 2rem;
    backdrop-filter: blur(8px);
    transition: background 0.2s;
  }
  .feat-card:hover { background: rgba(255, 255, 255, 0.03); }
  .feat-icon {
    width: 36px; height: 36px;
    color: var(--teal);
    margin-bottom: 1rem;
    opacity: 0.9;
  }
  .feat-icon svg { width: 100%; height: 100%; }
  .feat-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .feat-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #9a9a9a;
  }

  /* ── COMPATIBLE WITH ── */
  .compat {
    position: relative;
    z-index: 1;
    padding: 3rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .compat-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .compat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #aaaaaa;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .compat-logos {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .compat-logo {
    height: 44px;
    width: auto;
    background: #fff;
    border-radius: 6px;
    padding: 6px 14px;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .compat-logo:hover { opacity: 1; }

  /* ── DEMO ── */
  .demo {
    position: relative;
    z-index: 1;
    padding: 8rem 0;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.01) 50%, transparent);
  }
  .demo-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 5rem;
    align-items: center;
  }
  .video-phone {
    position: relative;
    width: 240px;
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid rgba(226, 226, 226, 0.1);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.06),
      0 24px 64px rgba(0,0,0,0.6);
    cursor: pointer;
  }
  .video-phone video {
    display: block;
    width: 100%;
  }
  .video-play-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0);
    transition: background 0.2s;
  }
  .video-play-hint svg {
    width: 48px; height: 48px;
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
  }
  .video-phone:hover .video-play-hint { background: rgba(0,0,0,0.25); }
  .video-phone:hover .video-play-hint svg { opacity: 1; }

  /* Modal */
  .video-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .video-modal.open {
    opacity: 1;
    pointer-events: all;
  }
  .video-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .video-modal-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    transform: scale(0.95);
    transition: transform 0.25s;
  }
  .video-modal.open .video-modal-inner { transform: scale(1); }
  .video-modal-close {
    align-self: flex-end;
    background: none;
    border: 1px solid rgba(226,226,226,0.2);
    color: var(--text);
    font-size: 1.4rem;
    line-height: 1;
    width: 36px; height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .video-modal-close:hover { background: rgba(255,255,255,0.1); }
  .video-modal-phone {
    width: min(360px, 80vw);
    border-radius: 36px;
    overflow: hidden;
    border: 1px solid rgba(226,226,226,0.15);
    box-shadow: 0 32px 80px rgba(0,0,0,0.8);
  }
  .video-modal-phone video {
    display: block;
    width: 100%;
  }
  .demo-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1.15;
    margin: 1rem 0 1.25rem;
  }
  .demo-text p {
    color: #aaaaaa;
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .terminal {
    background: #0f0f0f;
    border: 1px solid rgba(226, 226, 226, 0.1);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(0, 0, 0, 0.3);
  }
  .dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    opacity: 0.8;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    margin-left: 8px;
    letter-spacing: 0.03em;
  }
  .terminal-body {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
    overflow-x: auto;
  }
  .c-kw    { color: #cccccc; font-weight: 500; }
  .c-label { color: #aaaaaa; }
  .c-rel   { color: #e8e8e8; }
  .c-var   { color: #bbbbbb; }
  .c-str   { color: #aaaaaa; }
  .c-num   { color: #e8e8e8; }
  .c-prop  { color: #dddddd; }
  .c-punc  { color: #aaaaaa; }
  .c-op    { color: #aaaaaa; }
  .c-cursor {
    display: inline-block;
    width: 2px; height: 1em;
    background: var(--teal);
    animation: blink 1.2s step-end infinite;
    vertical-align: middle;
    margin-left: 1px;
  }
  .terminal-result {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1rem 1.5rem;
  }
  .result-row {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: #9a9a9a;
  }
  .result-row.header {
    color: #666666;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-bottom: 0.5rem;
  }
  .result-row span:first-child { flex: 1; color: #aaaaaa; }
  .result-meta {
    padding-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  /* ── PLATFORMS ── */
  .platforms {
    position: relative;
    z-index: 1;
    padding: 7rem 0;
  }
  .platform-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-top: 3rem;
  }
  .platform-card {
    background: var(--card-bg);
    padding: 2.5rem 2rem;
    text-align: center;
    transition: background 0.2s;
    backdrop-filter: blur(8px);
  }
  .platform-card:hover { background: rgba(255, 255, 255, 0.03); }
  .platform-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }
  .platform-name {
    font-weight: 700;
    font-size: 1rem;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }
  .platform-detail {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  /* ── CTA ── */
  .cta {
    position: relative;
    z-index: 1;
    padding: 8rem 0;
    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .cta-icon {
    width: 72px; height: 72px;
  }
  .cta-text h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .cta-text p {
    color: #aaaaaa;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  /* ── FOOTER ── */

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  @keyframes nodePulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.5); opacity: 0.5; }
  }
  @keyframes scrollDrop {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-visual { display: none; }
    .feat-grid { grid-template-columns: repeat(2, 1fr); }
    .demo-inner { grid-template-columns: 1fr; gap: 3rem; }
    .video-phone { margin: 0 auto; }
    .platform-grid { grid-template-columns: repeat(2, 1fr); }

  }
  @media (max-width: 600px) {
    .feat-grid { grid-template-columns: 1fr; }
    .platform-grid { grid-template-columns: 1fr; }
    h1 { font-size: 2.2rem; }
  }
</style>

<script>
  // Video modal
  const thumb   = document.getElementById('video-thumb')!;
  const modal   = document.getElementById('video-modal')!;
  const player  = document.getElementById('video-modal-player') as HTMLVideoElement;
  const closeBtn = modal.querySelector('.video-modal-close')!;
  const backdrop = modal.querySelector('.video-modal-backdrop')!;

  function openModal() {
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    player.currentTime = 0;
    player.play();
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    player.pause();
    document.body.style.overflow = '';
  }

  thumb.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // Canvas Neo4j-style graph animation
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  interface GNode { x: number; y: number; vx: number; vy: number; label: string; r: number; phase: number; }
  interface GEdge { from: number; to: number; rel: string; }

  let W = 0, H = 0;
  let mouse = { x: -9999, y: -9999 };

  const NODE_LABELS = ['Person','Movie','City','Actor','Event','Place','User','Company','Product','Artist','Album','Genre'];
  const EDGES: GEdge[] = [
    { from:0, to:1, rel:'ACTED_IN' },
    { from:0, to:2, rel:'LIVES_IN' },
    { from:0, to:6, rel:'KNOWS' },
    { from:0, to:5, rel:'VISITED' },
    { from:1, to:11, rel:'HAS_GENRE' },
    { from:2, to:4, rel:'HOSTS' },
    { from:3, to:1, rel:'DIRECTED' },
    { from:3, to:9, rel:'IS' },
    { from:5, to:2, rel:'PART_OF' },
    { from:6, to:7, rel:'WORKS_AT' },
    { from:6, to:8, rel:'PURCHASED' },
    { from:7, to:4, rel:'SPONSORED' },
    { from:9, to:10, rel:'RELEASED' },
    { from:10, to:11, rel:'HAS_GENRE' },
  ];

  let nodes: GNode[] = [];

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  // Pre-spread positions across the screen (as fractions)
  const SPREAD = [
    [0.08, 0.12], [0.30, 0.08], [0.58, 0.06], [0.82, 0.18],
    [0.92, 0.48], [0.78, 0.78], [0.52, 0.88], [0.24, 0.82],
    [0.06, 0.55], [0.18, 0.30], [0.46, 0.42], [0.70, 0.38],
  ];

  function init() {
    resize();
    nodes = NODE_LABELS.map((label, i) => ({
      x: SPREAD[i][0] * W + (Math.random() - 0.5) * 60,
      y: SPREAD[i][1] * H + (Math.random() - 0.5) * 60,
      vx: (Math.random() - 0.5) * 0.06,
      vy: (Math.random() - 0.5) * 0.06,
      label,
      r: label.length > 6 ? 30 : 26,
      phase: Math.random() * Math.PI * 2,
    }));
  }

  function drawArrow(x1: number, y1: number, x2: number, y2: number, r1: number, r2: number, alpha: number) {
    const angle = Math.atan2(y2 - y1, x2 - x1);
    const sx = x1 + Math.cos(angle) * r1;
    const sy = y1 + Math.sin(angle) * r1;
    const ex = x2 - Math.cos(angle) * (r2 + 9);
    const ey = y2 - Math.sin(angle) * (r2 + 9);
    if (Math.sqrt((ex-sx)**2 + (ey-sy)**2) < 10) return;

    ctx.strokeStyle = `rgba(226,226,226,${alpha})`;
    ctx.lineWidth = 0.8;
    ctx.beginPath();
    ctx.moveTo(sx, sy);
    ctx.lineTo(ex, ey);
    ctx.stroke();

    const aSize = 7;
    ctx.fillStyle = `rgba(226,226,226,${alpha})`;
    ctx.beginPath();
    ctx.moveTo(ex, ey);
    ctx.lineTo(ex - aSize * Math.cos(angle - 0.38), ey - aSize * Math.sin(angle - 0.38));
    ctx.lineTo(ex - aSize * Math.cos(angle + 0.38), ey - aSize * Math.sin(angle + 0.38));
    ctx.closePath();
    ctx.fill();
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, W, H);

    // home pull — gently keep nodes near their spread positions
    for (let i = 0; i < nodes.length; i++) {
      const hx = SPREAD[i][0] * W, hy = SPREAD[i][1] * H;
      nodes[i].vx += (hx - nodes[i].x) * 0.00018;
      nodes[i].vy += (hy - nodes[i].y) * 0.00018;
    }

    for (const n of nodes) {
      n.vx *= 0.97; n.vy *= 0.97;
      const spd = Math.sqrt(n.vx*n.vx + n.vy*n.vy);
      if (spd > 0.35) { n.vx = n.vx/spd * 0.35; n.vy = n.vy/spd * 0.35; }
      n.x += n.vx; n.y += n.vy;
      n.x = Math.max(n.r + 4, Math.min(W - n.r - 4, n.x));
      n.y = Math.max(n.r + 4, Math.min(H - n.r - 4, n.y));
    }

    // draw edges + rel labels
    for (const e of EDGES) {
      const a = nodes[e.from], b = nodes[e.to];
      const near = Math.hypot(mouse.x - a.x, mouse.y - a.y) < 180 || Math.hypot(mouse.x - b.x, mouse.y - b.y) < 180;
      drawArrow(a.x, a.y, b.x, b.y, a.r, b.r, near ? 0.28 : 0.1);

      const angle = Math.atan2(b.y - a.y, b.x - a.x);
      const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2;
      ctx.save();
      ctx.translate(mx, my);
      let rot = angle;
      if (rot > Math.PI/2 || rot < -Math.PI/2) rot += Math.PI;
      ctx.rotate(rot);
      ctx.font = '9px IBM Plex Mono, monospace';
      ctx.fillStyle = `rgba(226,226,226,${near ? 0.3 : 0.12})`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText(e.rel, 0, -4);
      ctx.restore();
    }

    // draw nodes
    for (const n of nodes) {
      const pulse  = Math.sin(t * 0.0007 + n.phase) * 0.04 + 1;
      const hovered = Math.hypot(mouse.x - n.x, mouse.y - n.y) < 180;
      const r      = n.r * pulse;

      ctx.beginPath();
      ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle   = `rgba(226,226,226,${hovered ? 0.08 : 0.03})`;
      ctx.fill();
      ctx.strokeStyle = `rgba(226,226,226,${hovered ? 0.55 : 0.18})`;
      ctx.lineWidth   = 1.2;
      ctx.stroke();

      ctx.font         = `bold 10px IBM Plex Mono, monospace`;
      ctx.fillStyle    = `rgba(226,226,226,${hovered ? 0.75 : 0.25})`;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(n.label, n.x, n.y);
    }

    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', () => resize(), { passive: true });
  window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; }, { passive: true });
  window.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; }, { passive: true });
  init();
  requestAnimationFrame(draw);

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.feat-card, .platform-card, .terminal').forEach(el => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(20px)';
    (el as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(el);
  });
</script>

</body>
</html>
